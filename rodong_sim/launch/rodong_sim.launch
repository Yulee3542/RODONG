<?xml version="1.0"?>
<!--
  rodong_sim.launch — simple box-model Gazebo + RODONG FSM/avoidance nodes.
  Run:
    roslaunch rodong_sim rodong_sim.launch
  Start driving (IDLE→BUG_DRIVE):
    rostopic pub -1 /rodong/cmd std_msgs/String "data: 'INIT'"
-->
<launch>

  <!-- Application code (patch) location. Override with app_dir:=... for a different path -->
  <arg name="app_dir" default="/workspace/rodong_pi_code/patch(20260602)"/>
  <arg name="gui"     default="true"/>
  <arg name="world"   default="obstacles.world"/>   <!-- swap world per scenario -->
  <arg name="spawn_x" default="0"/>                 <!-- spawn X (for the close-wall test) -->

  <!-- ── Gazebo ───────────────────────────────────────────────────── -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find rodong_sim)/worlds/$(arg world)"/>
    <arg name="gui"        value="$(arg gui)"/>
    <arg name="paused"     value="false"/>
    <arg name="use_sim_time" value="true"/>
  </include>

  <!-- ── robot spawn ──────────────────────────────────────────────── -->
  <param name="robot_description" textfile="$(find rodong_sim)/urdf/rodong_box.urdf"/>
  <node name="spawn_rodong" pkg="gazebo_ros" type="spawn_model" output="screen"
        args="-param robot_description -urdf -model rodong -x $(arg spawn_x) -y 0 -z 0.10"/>

  <!-- ── bridge (Gazebo ↔ Xycar topics) ──────────────────────────── -->
  <node name="sim_bridge" pkg="rodong_sim" type="sim_bridge.py" output="screen">
    <param name="speed_to_ms"   value="0.03"/>
    <param name="wheelbase"     value="0.30"/>
    <param name="max_steer_deg" value="60.0"/>
    <param name="max_cm"        value="300"/>
  </node>

  <!-- ── application nodes (run the patch originals as a single source) ────── -->
  <node name="vfh_planner" pkg="rodong_sim" type="run_app.py" output="screen"
        args="$(arg app_dir) vfh_planner"/>
  <node name="rodong_main" pkg="rodong_sim" type="run_app.py" output="screen"
        args="$(arg app_dir) rodong_main"/>

  <!-- aruco_detector / yolo_node omitted (no marker/camera). With no marker visible,
       rodong_main stays in the BUG_DRIVE avoidance state. -->

</launch>
