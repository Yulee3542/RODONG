<?xml version="1.0"?>
<launch>
  <!-- ── Device nodes ──────────────────────────────────────── -->
  <include file="/home/pi/xycar_ws/src/xycar_device/xycar_ultrasonic_1x8/launch/xycar_ultrasonic.launch"/>
  <include file="/home/pi/xycar_ws/src/xycar_device/xycar_imu/launch/xycar_imu.launch"/>

  <node name="usb_cam" pkg="usb_cam" type="usb_cam_node" output="screen">
    <param name="video_device"  value="/dev/video0"/>
    <param name="image_width"   value="640"/>
    <param name="image_height"  value="480"/>
    <param name="pixel_format"  value="yuyv"/>
    <param name="camera_frame_id" value="usb_cam"/>
    <param name="io_method"     value="mmap"/>
  </node>

  <!-- ── Application nodes ─────────────────────────────────── -->
  <node name="aruco_detector" pkg="rodong" type="aruco_detector.py"  output="screen"/>
  <node name="vfh_planner"    pkg="rodong" type="vfh_planner.py"     output="screen"/>
  <node name="yolo_node"      pkg="rodong" type="yolo_node.py"        output="screen"/>

  <!-- Floor black-boundary detection → /rodong/boundary (stay inside the boundary)
       NOTE: currently disabled (too sensitive). To re-enable, uncomment below and tune
       thresholds. vfh_planner's subscription is auto-ignored via BOUND_TIMEOUT when
       there is no publisher. -->
  <!--
  <node name="line_detector"  pkg="rodong" type="line_detector.py"    output="screen">
    <param name="black_v_max" value="60"/>     <!- - V<=this → black (raise if bright / lower if shadowy) - ->
    <param name="black_s_max" value="255"/>    <!- - S upper bound (ignored by default) - ->
    <param name="roi_top"     value="0.55"/>   <!- - ROI start height ratio (view only the floor) - ->
    <param name="near_top"    value="0.85"/>   <!- - near-strip start height ratio - ->
    <param name="min_ratio"   value="0.04"/>   <!- - noise cut - ->
    <param name="debug"       value="false"/>  <!- - true: /rodong/boundary_debug image - ->
  </node>
  -->

  <include file="/home/pi/xycar_ws/src/xycar_device/xycar_motor/launch/xycar_motor.launch"/>

  <!-- Main (starts in IDLE — waits for teleop INIT command) -->
  <node name="rodong_main"    pkg="rodong" type="rodong_main.py"      output="screen"/>

  <!-- ── Teleop (recommended to run in a separate terminal; optional here) ─ -->
  <!--
    If included in the launch, key input is buried in one terminal and does not work.
    Run in a separate terminal:
      rosrun rodong rodong_teleop.py
  -->

</launch>
